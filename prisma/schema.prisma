// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Enums
// ============================================================

enum Role {
  sales
  manager
  admin
}

// ============================================================
// Models
// ============================================================

/// ユーザーマスタ（営業担当者・上長・管理者）
model User {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(50)
  email     String   @unique @db.VarChar(255)
  password  String
  role      Role
  managerId String?  @map("manager_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  // 自己参照リレーション（上長）
  manager      User?  @relation("UserManager", fields: [managerId], references: [id])
  subordinates User[] @relation("UserManager")

  // 担当顧客
  assignedCustomers Customer[]

  // 作成した日報
  dailyReports DailyReport[] @relation("ReportAuthor")

  // コメントした日報
  commentedReports DailyReport[] @relation("ReportCommenter")

  @@map("users")
}

/// 顧客マスタ
model Customer {
  id             String   @id @default(uuid()) @db.Uuid
  name           String   @db.VarChar(100)
  industry       String?  @db.VarChar(100)
  assignedUserId String?  @map("assigned_user_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  assignedUser User?         @relation(fields: [assignedUserId], references: [id])
  visitRecords VisitRecord[]

  @@map("customers")
}

/// 日報
model DailyReport {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  reportDate     DateTime  @map("report_date") @db.Date
  problem        String
  plan           String
  managerComment String?   @map("manager_comment")
  commentedBy    String?   @map("commented_by") @db.Uuid
  commentedAt    DateTime? @map("commented_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user         User          @relation("ReportAuthor", fields: [userId], references: [id])
  commenter    User?         @relation("ReportCommenter", fields: [commentedBy], references: [id])
  visitRecords VisitRecord[]

  // 同一ユーザー・同一日付の日報はひとつのみ
  @@unique([userId, reportDate])
  @@map("daily_reports")
}

/// 訪問記録（日報の明細）
model VisitRecord {
  id         String @id @default(uuid()) @db.Uuid
  reportId   String @map("report_id") @db.Uuid
  customerId String @map("customer_id") @db.Uuid
  visitNote  String @map("visit_note")
  visitOrder Int    @map("visit_order")

  report   DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  customer Customer    @relation(fields: [customerId], references: [id])

  @@map("visit_records")
}
